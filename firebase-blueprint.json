{
  "entities": {
    "SearchEvent": {
      "title": "Search Event",
      "description": "Records a user's location search query.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "location": { "type": "string" },
        "category": { "type": "string" },
        "pricingTier": { "type": "string" },
        "currency": { "type": "string" },
        "createdAt": { "type": "number", "description": "Server timestamp" }
      },
      "required": ["userId", "location", "category", "pricingTier", "currency", "createdAt"]
    }
  },
  "firestore": {
    "/searches/{searchId}": {
      "schema": { "$ref": "#/entities/SearchEvent" },
      "description": "Stored searches."
    }
  }
}
