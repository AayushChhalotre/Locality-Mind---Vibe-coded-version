rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidSearchEvent(data) {
      return data.keys().hasAll(['userId', 'location', 'category', 'pricingTier', 'currency', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid &&
             data.location is string && data.location.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.pricingTier is string && data.pricingTier.size() <= 100 &&
             data.currency is string && data.currency.size() <= 10 &&
             data.createdAt == request.time;
    }

    match /searches/{searchId} {
      allow create: if isSignedIn() && isValidId(searchId) && isValidSearchEvent(incoming());
    }
  }
}
